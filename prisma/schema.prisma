generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                 String                              @id @default(cuid())
  email                              String                              @unique
  username                           String                              @unique @db.VarChar(18)
  name                               String?
  onboarded                          Boolean                             @default(false)
  aiExperienceLevel                  UserExperienceLevel?
  vibeCodingExperienceLevel          UserExperienceLevel?
  onboardingGoal                     String?                             @db.Text
  createdAt                          DateTime                            @default(now())
  updatedAt                          DateTime                            @updatedAt
  sessions                           Session[]
  authTokens                         AuthToken[]
  projects                           Project[]
  projectMemberships                 ProjectMember[]
  oauthAuthorizationCodes            OAuthAuthorizationCode[]
  oauthAccessTokens                  OAuthAccessToken[]
  projectIntegrationGrants           ProjectIntegrationGrant[]
  agentRuns                          AgentRun[]
  projectAgentChatMessages           ProjectAgentChatMessage[]
  projectAgentChatMessageAttachments ProjectAgentChatMessageAttachment[]
  userAgentChatMessageAttachments    UserAgentChatMessageAttachment[]
  userAgentChatMessages              UserAgentChatMessage[]
  uploadedFiles                      UploadedFile[]
  hubTopics                          HubTopic[]
  hubArtifacts                       HubArtifact[]
  hubComments                        HubComment[]
  hubUpvotes                         HubUpvote[]
  hubDownvotes                       HubDownvote[]
  hubCommentUpvotes                  HubCommentUpvote[]
  hubCommentDownvotes                HubCommentDownvote[]
  ownedBillingAccounts               BillingAccount[]
  creditLedgerEntries                CreditLedgerEntry[]

  @@map("users")
}

enum UserExperienceLevel {
  none
  beginner
  advanced

  @@map("user_experience_level")
}

model Project {
  id              String    @id
  userId          String
  templateId      String
  templateName    String
  templateImage   String?   @db.VarChar(255)
  git             String    @db.VarChar(1024)
  slug            String    @unique @db.VarChar(64)
  domain          String    @db.VarChar(255)
  devDomain       String?   @unique @db.VarChar(255)
  url             String    @db.VarChar(255)
  devUrl          String?   @db.VarChar(255)
  status          String    @default("deploying") @db.VarChar(32)
  appPort         Int
  agentPort       Int
  agentToolsToken String?   @db.VarChar(128)
  managerJobId    String?   @db.VarChar(128)
  deployError     String?   @db.Text
  resources       Json?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user                               User                                @relation(fields: [userId], references: [id], onDelete: Cascade)
  members                            ProjectMember[]
  oauthClient                        OAuthClient?
  integrationGrants                  ProjectIntegrationGrant[]
  agentRuns                          AgentRun[]
  projectAgentChatMessages           ProjectAgentChatMessage[]
  projectAgentChatMessageAttachments ProjectAgentChatMessageAttachment[]
  authTokens                         AuthToken[]
  creditLedgerEntries                CreditLedgerEntry[]
  uploadedFiles                      UploadedFile[]

  @@index([domain])
  @@index([devDomain])
  @@index([userId, deletedAt, createdAt])
  @@map("projects")
}

enum ProjectMemberRole {
  admin
  editor
  viewer

  @@map("project_member_role")
}

model ProjectMember {
  id        String            @id @default(cuid())
  projectId String
  userId    String
  role      ProjectMemberRole
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId, role])
  @@index([projectId, role])
  @@map("project_members")
}

model AppTemplate {
  id          String   @id @db.VarChar(64)
  slug        String   @unique @db.VarChar(64)
  name        String   @db.VarChar(128)
  description String   @db.Text
  icon        String   @db.VarChar(64)
  status      String   @default("coming_soon") @db.VarChar(32)
  repository  String?  @db.VarChar(128)
  git         String?  @db.VarChar(255)
  image       String?  @db.VarChar(255)
  appPort     Int?
  agentPort   Int?
  hubTopicId  String?  @db.VarChar(64)
  sortOrder   Int      @default(0)
  manifestUrl String?  @db.VarChar(512)
  manifest    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  translations AppTemplateTranslation[]

  @@index([status, sortOrder])
  @@map("app_templates")
}

model AppTemplateTranslation {
  id          String @id @default(cuid())
  templateId  String @db.VarChar(64)
  locale      String @db.VarChar(8)
  name        String @db.VarChar(128)
  description String @db.Text

  template AppTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, locale])
  @@index([locale])
  @@map("app_template_translations")
}

model OAuthClient {
  id                    String    @id @default(cuid())
  projectId             String    @unique
  name                  String    @db.VarChar(128)
  clientId              String    @unique @db.VarChar(128)
  clientSecretHash      String    @db.VarChar(255)
  clientSecretEncrypted String    @db.Text
  redirectUri           String    @db.VarChar(1024)
  revokedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  project            Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorizationCodes OAuthAuthorizationCode[]
  accessTokens       OAuthAccessToken[]

  @@index([projectId, revokedAt])
  @@map("oauth_clients")
}

model OAuthAuthorizationCode {
  id          String    @id @default(cuid())
  codeHash    String    @unique @db.VarChar(255)
  clientId    String
  userId      String
  redirectUri String    @db.VarChar(1024)
  scope       String?   @db.VarChar(512)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  client OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId, expiresAt])
  @@index([userId, createdAt])
  @@map("oauth_authorization_codes")
}

model OAuthAccessToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @db.VarChar(255)
  clientId  String
  userId    String
  scope     String?   @db.VarChar(512)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  client OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId, expiresAt])
  @@index([userId, createdAt])
  @@map("oauth_access_tokens")
}

model ProjectIntegrationGrant {
  id                    String    @id @default(cuid())
  projectId             String
  userId                String
  integrationId         String    @db.VarChar(64)
  provider              String    @db.VarChar(64)
  scopes                String[]
  accessTokenEncrypted  String?   @db.Text
  refreshTokenEncrypted String?   @db.Text
  tokenType             String    @default("Bearer") @db.VarChar(32)
  expiresAt             DateTime?
  revokedAt             DateTime?
  metadata              Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, integrationId])
  @@index([projectId, integrationId, provider])
  @@index([userId, provider])
  @@map("project_integration_grants")
}

model ProjectAgentChatMessage {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  role      String   @db.VarChar(16)
  source    String   @default("user") @db.VarChar(32)
  mode      String   @db.VarChar(16)
  content   String   @db.Text
  createdAt DateTime @default(now())

  user        User                                @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project                             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  attachments ProjectAgentChatMessageAttachment[]

  @@index([userId, projectId, createdAt])
  @@map("project_agent_chat_messages")
}

model ProjectAgentChatMessageAttachment {
  id             String   @id @default(cuid())
  messageId      String
  uploadedFileId String
  userId         String
  projectId      String
  createdAt      DateTime @default(now())

  message      ProjectAgentChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploadedFile UploadedFile            @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([messageId, uploadedFileId])
  @@index([userId, projectId, createdAt])
  @@index([uploadedFileId])
  @@map("project_agent_chat_message_attachments")
}

model UserAgentChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   @db.VarChar(16)
  content   String   @db.Text
  createdAt DateTime @default(now())

  user        User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments UserAgentChatMessageAttachment[]

  @@index([userId, createdAt])
  @@map("user_agent_chat_messages")
}

model UserAgentChatMessageAttachment {
  id             String   @id @default(cuid())
  messageId      String
  uploadedFileId String
  userId         String
  createdAt      DateTime @default(now())

  message      UserAgentChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploadedFile UploadedFile         @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, uploadedFileId])
  @@index([userId, createdAt])
  @@index([uploadedFileId])
  @@map("user_agent_chat_message_attachments")
}

model UploadedFile {
  id            String    @id @default(cuid())
  userId        String
  projectId     String?
  scope         String    @db.VarChar(32)
  originalName  String    @db.VarChar(255)
  mimeType      String    @db.VarChar(128)
  sizeBytes     Int
  storageBucket String    @db.VarChar(255)
  storageKey    String    @db.VarChar(1024)
  status        String    @default("queued") @db.VarChar(32)
  error         String?   @db.Text
  processedAt   DateTime?
  deletedAt     DateTime?
  thumbnailId   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user                               User                                @relation(fields: [userId], references: [id], onDelete: Cascade)
  project                            Project?                            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  thumbnail                          UploadedFile?                       @relation("UploadedFileThumbnail", fields: [thumbnailId], references: [id], onDelete: SetNull)
  thumbnailFor                       UploadedFile[]                      @relation("UploadedFileThumbnail")
  chunks                             UploadedFileChunk[]
  extractions                        UploadedFileExtraction[]
  projectAgentChatMessageAttachments ProjectAgentChatMessageAttachment[]
  userAgentChatMessageAttachments    UserAgentChatMessageAttachment[]
  hubArtifacts                       HubArtifact[]

  @@index([userId, scope, createdAt])
  @@index([projectId, createdAt])
  @@index([status, createdAt])
  @@index([thumbnailId])
  @@index([userId, deletedAt, createdAt])
  @@map("uploaded_files")
}

model UploadedFileExtraction {
  id             String   @id @default(cuid())
  uploadedFileId String
  format         String   @db.VarChar(32)
  content        String   @db.Text
  provider       String?  @db.VarChar(64)
  model          String?  @db.VarChar(128)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)

  @@unique([uploadedFileId, format])
  @@index([uploadedFileId, createdAt])
  @@map("uploaded_file_extractions")
}

model UploadedFileChunk {
  id                  String                       @id @default(cuid())
  uploadedFileId      String
  userId              String
  projectId           String?
  chunkIndex          Int
  content             String                       @db.Text
  embedding           Unsupported("vector(1536)")?
  embeddingModel      String?                      @db.VarChar(128)
  embeddingDimensions Int?
  metadata            Json?
  createdAt           DateTime                     @default(now())

  uploadedFile UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)

  @@unique([uploadedFileId, chunkIndex])
  @@index([userId, projectId, createdAt])
  @@map("uploaded_file_chunks")
}

model AgentRun {
  id              String    @id @default(cuid())
  requestId       String    @unique @db.VarChar(128)
  userId          String
  projectId       String?
  scope           String    @db.VarChar(32)
  mode            String    @default("use") @db.VarChar(16)
  status          String    @default("queued") @db.VarChar(32)
  inputMessageId  String?   @db.VarChar(255)
  outputMessageId String?   @db.VarChar(255)
  model           String?   @db.VarChar(128)
  payload         Json
  error           String?   @db.Text
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events  AgentRunEvent[]

  @@index([userId, scope, projectId, status, createdAt])
  @@index([status, createdAt])
  @@map("agent_runs")
}

model AgentRunEvent {
  id        String   @id @default(cuid())
  runId     String
  seq       Int
  type      String   @db.VarChar(32)
  payload   Json
  createdAt DateTime @default(now())

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, seq])
  @@index([runId, seq])
  @@map("agent_run_events")
}

model HubTopic {
  id          String   @id @default(cuid())
  slug        String?  @unique @db.VarChar(160)
  title       String   @db.VarChar(160)
  intent      String   @db.Text
  description String?  @db.Text
  category    String   @db.VarChar(32)
  status      String   @default("analyzing") @db.VarChar(32)
  visibility  String   @default("public") @db.VarChar(32)
  appUrl      String?  @db.VarChar(1024)
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author       User                  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  artifacts    HubArtifact[]
  comments     HubComment[]
  upvotes      HubUpvote[]
  downvotes    HubDownvote[]
  topicTags    HubTopicTag[]
  translations HubTopicTranslation[]

  @@index([category, createdAt])
  @@index([status, createdAt])
  @@index([visibility, createdAt])
  @@index([authorId, createdAt])
  @@map("hub_topics")
}

model HubTopicTranslation {
  id          String  @id @default(cuid())
  topicId     String
  locale      String  @db.VarChar(8)
  title       String  @db.VarChar(160)
  intent      String  @db.Text
  description String? @db.Text

  topic HubTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([topicId, locale])
  @@index([locale])
  @@map("hub_topic_translations")
}

model HubTag {
  id        String   @id @default(cuid())
  category  String   @db.VarChar(32)
  slug      String   @db.VarChar(64)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topicTags    HubTopicTag[]
  translations HubTagTranslation[]

  @@unique([category, slug])
  @@index([category, sortOrder])
  @@map("hub_tags")
}

model HubTagTranslation {
  id          String  @id @default(cuid())
  tagId       String
  locale      String  @db.VarChar(8)
  title       String  @db.VarChar(120)
  description String? @db.Text
  hint        String? @db.Text

  tag HubTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, locale])
  @@index([locale])
  @@map("hub_tag_translations")
}

model HubTopicTag {
  topicId String
  tagId   String

  topic HubTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  tag   HubTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([topicId, tagId])
  @@index([tagId])
  @@map("hub_topic_tags")
}

model HubArtifactTag {
  id        String   @id @default(cuid())
  slug      String   @unique @db.VarChar(64)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artifactTags HubArtifactTagAssignment[]
  translations HubArtifactTagTranslation[]

  @@index([sortOrder])
  @@map("hub_artifact_tags")
}

model HubArtifactTagTranslation {
  id          String  @id @default(cuid())
  tagId       String
  locale      String  @db.VarChar(8)
  title       String  @db.VarChar(120)
  description String? @db.Text
  hint        String? @db.Text

  tag HubArtifactTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, locale])
  @@index([locale])
  @@map("hub_artifact_tag_translations")
}

model HubArtifactTagAssignment {
  artifactId String
  tagId      String

  artifact HubArtifact    @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  tag      HubArtifactTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([artifactId, tagId])
  @@index([tagId])
  @@map("hub_artifact_tag_assignments")
}

model HubArtifact {
  id             String   @id @default(cuid())
  slug           String?  @unique @db.VarChar(160)
  topicId        String
  authorId       String
  uploadedFileId String?
  type           String   @db.VarChar(32)
  status         String   @default("analyzing") @db.VarChar(32)
  title          String   @db.VarChar(160)
  description    String?  @db.Text
  textContent    String?  @db.Text
  externalUrl    String?  @db.VarChar(1024)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  topic        HubTopic                   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author       User                       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  uploadedFile UploadedFile?              @relation(fields: [uploadedFileId], references: [id], onDelete: SetNull)
  comments     HubComment[]
  artifactTags HubArtifactTagAssignment[]
  translations HubArtifactTranslation[]

  @@index([topicId, createdAt])
  @@index([authorId, createdAt])
  @@index([uploadedFileId])
  @@map("hub_artifacts")
}

model HubArtifactTranslation {
  id         String @id @default(cuid())
  artifactId String
  locale     String @db.VarChar(8)
  title      String @db.VarChar(160)

  artifact HubArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([artifactId, locale])
  @@index([locale])
  @@map("hub_artifact_translations")
}

model HubComment {
  id         String   @id @default(cuid())
  topicId    String
  artifactId String?
  parentId   String?
  authorId   String
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  topic        HubTopic                @relation(fields: [topicId], references: [id], onDelete: Cascade)
  artifact     HubArtifact?            @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  parent       HubComment?             @relation("HubCommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies      HubComment[]            @relation("HubCommentThread")
  author       User                    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  upvotes      HubCommentUpvote[]
  downvotes    HubCommentDownvote[]
  translations HubCommentTranslation[]

  @@index([topicId, createdAt])
  @@index([artifactId, createdAt])
  @@index([parentId, createdAt])
  @@index([authorId, createdAt])
  @@map("hub_comments")
}

model HubCommentTranslation {
  id        String @id @default(cuid())
  commentId String
  locale    String @db.VarChar(8)
  body      String @db.Text

  comment HubComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, locale])
  @@index([locale])
  @@map("hub_comment_translations")
}

model HubCommentUpvote {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment HubComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId, createdAt])
  @@map("hub_comment_upvotes")
}

model HubCommentDownvote {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment HubComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId, createdAt])
  @@map("hub_comment_downvotes")
}

model HubUpvote {
  id        String   @id @default(cuid())
  topicId   String
  userId    String
  createdAt DateTime @default(now())

  topic HubTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
  @@index([userId, createdAt])
  @@map("hub_upvotes")
}

model HubDownvote {
  id        String   @id @default(cuid())
  topicId   String
  userId    String
  createdAt DateTime @default(now())

  topic HubTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([topicId, userId])
  @@index([userId, createdAt])
  @@map("hub_downvotes")
}

model AgentUsage {
  id                 String   @id @default(cuid())
  requestId          String   @unique @db.VarChar(128)
  userId             String
  projectId          String?
  userMessageId      String?  @db.VarChar(255)
  assistantMessageId String?  @db.VarChar(255)
  mode               String   @db.VarChar(16)
  model              String?  @db.VarChar(128)
  promptTokens       Int?
  completionTokens   Int?
  totalTokens        Int?
  createdAt          DateTime @default(now())

  @@index([userId, projectId, createdAt])
  @@index([assistantMessageId])
  @@map("agent_usage")
}

model BillingAccount {
  id            String   @id @default(cuid())
  ownerUserId   String
  creditBalance Decimal  @default(0) @db.Decimal(18, 0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner         User                @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  ledgerEntries CreditLedgerEntry[]

  @@unique([ownerUserId])
  @@map("billing_accounts")
}

model UsagePrice {
  id            String    @id @default(cuid())
  meterType     String    @db.VarChar(64)
  provider      String?   @db.VarChar(64)
  model         String?   @db.VarChar(128)
  unit          String    @db.VarChar(64)
  inputCredits  Decimal?  @db.Decimal(18, 0)
  outputCredits Decimal?  @db.Decimal(18, 0)
  unitCredits   Decimal?  @db.Decimal(18, 0)
  inputCostUsd  Decimal?  @db.Decimal(18, 8)
  outputCostUsd Decimal?  @db.Decimal(18, 8)
  unitCostUsd   Decimal?  @db.Decimal(18, 8)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([meterType, provider, model, effectiveTo])
  @@map("usage_prices")
}

model CreditLedgerEntry {
  id          String   @id @default(cuid())
  accountId   String
  actorUserId String?
  projectId   String?
  sourceType  String   @db.VarChar(64)
  sourceId    String   @db.VarChar(128)
  meterType   String   @db.VarChar(64)
  credits     Decimal  @db.Decimal(18, 0)
  costUsd     Decimal? @db.Decimal(18, 8)
  description String   @db.VarChar(255)
  metadata    Json?
  createdAt   DateTime @default(now())

  account   BillingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  actorUser User?          @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  project   Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([sourceType, sourceId, meterType])
  @@index([accountId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([projectId, createdAt])
  @@map("credit_ledger_entries")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique @db.VarChar(128)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuthToken {
  id             String    @id @default(cuid())
  subjectType    String    @db.VarChar(32)
  userId         String?
  projectId      String?
  scope          String    @db.VarChar(64)
  name           String    @db.VarChar(128)
  tokenHash      String    @unique @db.VarChar(128)
  encryptedToken String?   @db.Text
  tokenLast4     String    @db.VarChar(8)
  expiresAt      DateTime?
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([subjectType, scope, revokedAt])
  @@index([userId, scope, revokedAt, createdAt])
  @@index([projectId, scope, revokedAt])
  @@index([projectId, userId, scope, revokedAt])
  @@map("auth_tokens")
}
