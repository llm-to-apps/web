generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String?
  authHash          String             @map("passwordHash") @db.VarChar(255)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessions          Session[]
  projects          Project[]
  agentChatMessages AgentChatMessage[]

  @@map("users")
}

model Project {
  id              String   @id
  userId          String
  templateId      String
  templateName    String
  git             String   @db.VarChar(1024)
  domain          String   @db.VarChar(255)
  url             String   @db.VarChar(255)
  status          String   @default("deploying") @db.VarChar(32)
  appPort         Int
  agentPort       Int
  agentToolsToken String?  @db.VarChar(128)
  appMcpToken     String?  @db.VarChar(128)
  managerJobId    String?  @db.VarChar(128)
  deployError     String?  @db.Text
  resources       Json?
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentChatMessages AgentChatMessage[]

  @@index([domain])
  @@index([userId, deletedAt, createdAt])
  @@map("projects")
}

model AppTemplate {
  id          String   @id @db.VarChar(64)
  slug        String   @unique @db.VarChar(64)
  name        String   @db.VarChar(128)
  description String   @db.Text
  icon        String   @db.VarChar(64)
  status      String   @default("coming_soon") @db.VarChar(32)
  repository  String?  @db.VarChar(128)
  git         String?  @db.VarChar(255)
  image       String?  @db.VarChar(255)
  appPort     Int?
  agentPort   Int?
  sortOrder   Int      @default(0)
  manifestUrl String?  @db.VarChar(512)
  manifest    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, sortOrder])
  @@map("app_templates")
}

model AgentChatMessage {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  role      String   @db.VarChar(16)
  mode      String   @db.VarChar(16)
  content   String   @db.Text
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, projectId, createdAt])
  @@map("agent_chat_messages")
}

model AgentUsage {
  id                 String   @id @default(cuid())
  requestId          String   @unique @db.VarChar(128)
  userId             String
  projectId          String
  userMessageId      String?  @db.VarChar(255)
  assistantMessageId String?  @db.VarChar(255)
  mode               String   @db.VarChar(16)
  model              String?  @db.VarChar(128)
  promptTokens       Int?
  completionTokens   Int?
  totalTokens        Int?
  createdAt          DateTime @default(now())

  @@index([userId, projectId, createdAt])
  @@index([assistantMessageId])
  @@map("agent_usage")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique @db.VarChar(128)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}
