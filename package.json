{
  "name": "@os7/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && prisma db push && npm run seed && next dev",
    "worker": "npm run worker:build && node dist-worker/worker/deploy-worker.js",
    "worker:start": "node dist-worker/worker/deploy-worker.js",
    "worker:build": "tsc -p tsconfig.worker.json",
    "build": "next build && npm run worker:build",
    "start": "next start",
    "cli": "tsx cli/index.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "seed": "node --experimental-strip-types prisma/seed.ts",
    "slugs:build": "node scripts/build-slug-words.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "ajv": "^8.20.0",
    "bullmq": "^5.78.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^15.0.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.555.0",
    "next": "^16.0.7",
    "prisma": "^6.19.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.13.14",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
