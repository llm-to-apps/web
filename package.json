{
  "name": "@os7/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && prisma db push && npm run seed && next dev",
    "worker": "npm run worker:build && node dist-worker/worker/deploy-worker.js",
    "worker:start": "node dist-worker/worker/deploy-worker.js",
    "worker:build": "tsc -p tsconfig.worker.json",
    "build": "next build && npm run worker:build",
    "start": "next start",
    "cli": "tsx cli/index.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "seed": "node --experimental-strip-types prisma/seed.ts",
    "slugs:build": "node scripts/build-slug-words.mjs"
  },
  "dependencies": {
    "@mantine/core": "^9.3.1",
    "@mantine/hooks": "^9.3.1",
    "@mantine/notifications": "^9.3.1",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.58.0",
    "ajv": "^8.20.0",
    "bullmq": "^5.78.0",
    "commander": "^15.0.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.555.0",
    "next": "^16.0.7",
    "prisma": "^6.19.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
