{
  "name": "@llm-to-apps/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && prisma db push && next dev",
    "worker": "npm run worker:build && node dist-worker/worker/deploy-worker.js",
    "worker:start": "node dist-worker/worker/deploy-worker.js",
    "worker:build": "tsc -p tsconfig.worker.json",
    "build": "next build && npm run worker:build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "subdomains:build": "node scripts/build-subdomain-words.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.78.0",
    "lucide-react": "^0.555.0",
    "next": "^16.0.7",
    "prisma": "^6.19.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.8.3"
  }
}
